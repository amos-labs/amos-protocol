# AMOS Harness - Local Development Configuration
# Copy to .env and adjust values for your environment.
# Config uses AMOS__ prefix with __ as nested separator.

# Database (PostgreSQL)
AMOS__DATABASE__URL=postgres://your_user@localhost:5432/amos_harness_development
# Connection pool tuning (defaults shown; POOL_SIZE also accepts the
# legacy alias AMOS__DATABASE__MAX_CONNECTIONS)
# AMOS__DATABASE__POOL_SIZE=40
# AMOS__DATABASE__MIN_CONNECTIONS=5
# AMOS__DATABASE__ACQUIRE_TIMEOUT_SECS=10
# AMOS__DATABASE__IDLE_TIMEOUT_SECS=600
# AMOS__DATABASE__MAX_LIFETIME_SECS=1800

# Redis
AMOS__REDIS__URL=redis://127.0.0.1:6379

# Server
AMOS__SERVER__HOST=0.0.0.0
AMOS__SERVER__PORT=3000

# AWS Bedrock - reads from ~/.aws/credentials + ~/.aws/config automatically
# Set profile if not using default:
# AWS_PROFILE=your-profile

# Agent loop
AMOS__AGENT__MAX_ITERATIONS=25
AMOS__AGENT__MAX_CONTEXT_TOKENS=200000

# Solana (mainnet) — required for bounty settlement
# AMOS__SOLANA__RPC_URL=https://api.mainnet-beta.solana.com
# AMOS__SOLANA__ORACLE_KEYPAIR_PATH=/path/to/oracle-keypair.json
# AMOS__SOLANA__MINT_ADDRESS=5g9vvce3YLsqZPBGAuKmGFfNKb5sp7v3Wiga5de8d5bQ
# AMOS__SOLANA__TREASURY_TOKEN_ACCOUNT=9xDVHuW4kiUYH5NPDLFfKhpxLQ31N6bqMrvj4EJ57z2B

# Relay integration
# AMOS__RELAY__ENABLED=true
# AMOS__RELAY__URL=http://localhost:4100

# ─── Communication channels ─────────────────────────────────────────────

# Email (AWS SES v2) — uses the same AWS credential chain as Bedrock.
# Required to enable the send_email tool and SendNotification(channel=email).
# AMOS__EMAIL__FROM_ADDRESS=no-reply@amoslabs.com
# AMOS__EMAIL__REPLY_TO=support@amoslabs.com
# AMOS__EMAIL__REGION=us-east-1

# Twilio (WhatsApp messaging via the Twilio Messaging API).
# Enable the WhatsApp sandbox at console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
# AMOS__TWILIO__ACCOUNT_SID=AC...
# AMOS__TWILIO__AUTH_TOKEN=...
# AMOS__TWILIO__FROM_NUMBER=whatsapp:+14155238886    # sandbox number

# Discord (optional default webhook). Users can always pass webhook_url per call.
# AMOS__DISCORD__DEFAULT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── OAuth2 integrations ────────────────────────────────────────────────

# Public base URL of this harness. Used to build the OAuth2 redirect URI.
# Must match what the customer registers with each OAuth provider.
# Example: harness at https://jana.amoslabs.com → callback at
#          https://jana.amoslabs.com/api/v1/oauth/callback
AMOS__OAUTH__REDIRECT_BASE_URL=http://localhost:3000
