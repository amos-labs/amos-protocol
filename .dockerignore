# Build artifacts
target/

# Git
.git/
.gitignore

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Environment files (secrets)
.env
.env.local
.env.production

# Docker volumes and data
postgres_data/
redis_data/
localstack_data/

# OS files
.DS_Store
Thumbs.db

# Documentation (not needed in image)
*.md
LICENSE

# Exception: amos-oracle daemon reads these at startup so they MUST be in
# the build context. Without these unignore rules the oracle Dockerfile
# fails at COPY time.
!AGENT_CONTEXT.md
!docs/AMOS_THESIS_AND_STRATEGY.md
!amos-oracle/prompts/
!amos-oracle/prompts/*.md

# Test fixtures
tests/
test-data/

# Keys (mounted at runtime, not baked in)
keys/

# Logs
*.log
logs/
