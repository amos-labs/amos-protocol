{
  "family": "amos-oracle",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::637423327454:role/swarm-infrastructure-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::637423327454:role/swarm-infrastructure-rails-task-role",
  "containerDefinitions": [
    {
      "name": "amos-oracle",
      "image": "637423327454.dkr.ecr.us-east-1.amazonaws.com/amos-oracle:latest",
      "essential": true,
      "environment": [
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "ORACLE_RELAY_URL", "value": "https://relay.amoslabs.com" },
        { "name": "ORACLE_POSTER_WALLET", "value": "WxdXw1f1kFMRu8HDf1SE6yjgeWyf3Vb4T63QXMs4yij" },
        { "name": "ORACLE_REVIEWER_WALLET", "value": "5ik1JSm387xoEtzL5iNHc3wvVM12nzpPVJtaw4k1RHHY" },
        { "name": "ORACLE_PROMPT_VERSION", "value": "v1.1-launch-phase-2026-04-29" },
        { "name": "ORACLE_POLL_INTERVAL_SECS", "value": "60" },
        { "name": "ORACLE_PROJECT_ROOT", "value": "/app" },
        { "name": "RUST_LOG", "value": "info,amos_oracle=debug" },
        { "name": "RUST_BACKTRACE", "value": "1" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:637423327454:secret:amos-relay/database-url-E3v4GF"
        },
        {
          "name": "ORACLE_RELAY_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:637423327454:secret:amos-oracle/relay-api-key-woD1R4"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/amos-oracle",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "oracle"
        }
      }
    }
  ]
}
