{
  "name": "generic-crm",
  "version": "1",
  "components": [
    {
      "name": "contacts",
      "version": "1",
      "collections": [
        {
          "name": "people",
          "display_name": "People",
          "description": "Individuals you work with.",
          "fields": [
            { "name": "name", "display_name": "Name", "field_type": "text", "required": true },
            { "name": "email", "display_name": "Email", "field_type": "email" },
            { "name": "phone", "display_name": "Phone", "field_type": "phone" },
            { "name": "title", "display_name": "Title", "field_type": "text" },
            { "name": "company_ref", "display_name": "Company", "field_type": "reference", "options": { "collection": "companies" } },
            { "name": "notes", "display_name": "Notes", "field_type": "rich_text" }
          ]
        },
        {
          "name": "companies",
          "display_name": "Companies",
          "description": "Organizations you work with.",
          "fields": [
            { "name": "name", "display_name": "Name", "field_type": "text", "required": true },
            { "name": "website", "display_name": "Website", "field_type": "url" },
            { "name": "phone", "display_name": "Phone", "field_type": "phone" },
            { "name": "industry", "display_name": "Industry", "field_type": "text" },
            { "name": "address", "display_name": "Address", "field_type": "text" }
          ]
        }
      ],
      "canvases": [
        {
          "name": "People",
          "description": "All people.",
          "canvas_type": "datagrid",
          "data_sources": [{ "collection": "people" }]
        },
        {
          "name": "Companies",
          "description": "All companies.",
          "canvas_type": "datagrid",
          "data_sources": [{ "collection": "companies" }]
        }
      ]
    },
    {
      "name": "pipeline",
      "version": "1",
      "collections": [
        {
          "name": "deals",
          "display_name": "Deals",
          "description": "Sales opportunities.",
          "fields": [
            { "name": "title", "display_name": "Title", "field_type": "text", "required": true },
            { "name": "amount", "display_name": "Amount", "field_type": "number" },
            { "name": "stage", "display_name": "Stage", "field_type": "enum", "options": { "choices": ["prospect", "qualified", "proposal", "won", "lost"] } },
            { "name": "contact", "display_name": "Contact", "field_type": "reference", "options": { "collection": "people" } },
            { "name": "company", "display_name": "Company", "field_type": "reference", "options": { "collection": "companies" } },
            { "name": "close_date", "display_name": "Close Date", "field_type": "date" },
            { "name": "owner", "display_name": "Owner", "field_type": "text" }
          ]
        }
      ],
      "canvases": [
        {
          "name": "Pipeline",
          "description": "Deals by stage.",
          "canvas_type": "kanban",
          "data_sources": [{ "collection": "deals" }]
        },
        {
          "name": "Deals",
          "description": "All deals.",
          "canvas_type": "datagrid",
          "data_sources": [{ "collection": "deals" }]
        }
      ]
    },
    {
      "name": "activities",
      "version": "1",
      "collections": [
        {
          "name": "activities",
          "display_name": "Activities",
          "description": "Tasks, calls, meetings, and notes.",
          "fields": [
            { "name": "subject", "display_name": "Subject", "field_type": "text", "required": true },
            { "name": "kind", "display_name": "Kind", "field_type": "enum", "options": { "choices": ["task", "call", "email", "meeting", "note"] } },
            { "name": "due_at", "display_name": "Due", "field_type": "date_time" },
            { "name": "done", "display_name": "Done", "field_type": "boolean" },
            { "name": "related_deal", "display_name": "Related Deal", "field_type": "reference", "options": { "collection": "deals" } },
            { "name": "related_person", "display_name": "Related Person", "field_type": "reference", "options": { "collection": "people" } },
            { "name": "notes", "display_name": "Notes", "field_type": "rich_text" }
          ]
        }
      ],
      "canvases": [
        {
          "name": "Activity Calendar",
          "description": "Activities on a calendar.",
          "canvas_type": "calendar",
          "data_sources": [{ "collection": "activities" }]
        },
        {
          "name": "Tasks",
          "description": "All activities.",
          "canvas_type": "datagrid",
          "data_sources": [{ "collection": "activities" }]
        }
      ],
      "automations": [
        {
          "name": "Activity follow-up reminder",
          "description": "Notify when a new activity is created.",
          "trigger_type": "record_created",
          "trigger_config": { "collection": "activities" },
          "action_type": "send_notification",
          "action_config": { "message": "A new activity was created." }
        }
      ]
    },
    {
      "name": "documents",
      "version": "1",
      "collections": [
        {
          "name": "documents",
          "display_name": "Documents",
          "description": "Files attached to your work.",
          "fields": [
            { "name": "title", "display_name": "Title", "field_type": "text", "required": true },
            { "name": "file_url", "display_name": "File", "field_type": "url" },
            { "name": "doc_type", "display_name": "Type", "field_type": "enum", "options": { "choices": ["contract", "proposal", "invoice", "photo", "other"] } },
            { "name": "related_deal", "display_name": "Related Deal", "field_type": "reference", "options": { "collection": "deals" } },
            { "name": "signed", "display_name": "Signed", "field_type": "boolean" },
            { "name": "uploaded_at", "display_name": "Uploaded", "field_type": "date_time" }
          ]
        }
      ],
      "canvases": [
        {
          "name": "Documents",
          "description": "All documents.",
          "canvas_type": "datagrid",
          "data_sources": [{ "collection": "documents" }]
        }
      ]
    },
    {
      "name": "comms_log",
      "version": "1",
      "collections": [
        {
          "name": "messages",
          "display_name": "Messages",
          "description": "Email, SMS, call, and note history threaded to records.",
          "fields": [
            { "name": "channel", "display_name": "Channel", "field_type": "enum", "options": { "choices": ["email", "sms", "call", "note"] } },
            { "name": "direction", "display_name": "Direction", "field_type": "enum", "options": { "choices": ["inbound", "outbound"] } },
            { "name": "subject", "display_name": "Subject", "field_type": "text" },
            { "name": "body", "display_name": "Body", "field_type": "rich_text" },
            { "name": "related_person", "display_name": "Related Person", "field_type": "reference", "options": { "collection": "people" } },
            { "name": "related_deal", "display_name": "Related Deal", "field_type": "reference", "options": { "collection": "deals" } },
            { "name": "occurred_at", "display_name": "Occurred", "field_type": "date_time" }
          ]
        }
      ],
      "canvases": [
        {
          "name": "Communications",
          "description": "All logged communications.",
          "canvas_type": "datagrid",
          "data_sources": [{ "collection": "messages" }]
        }
      ]
    },
    {
      "name": "dashboards",
      "version": "1",
      "canvases": [
        {
          "name": "CRM Overview",
          "description": "At-a-glance state of your CRM.",
          "canvas_type": "dashboard"
        },
        {
          "name": "Pipeline Report",
          "description": "Deal flow and stage breakdown.",
          "canvas_type": "report"
        }
      ]
    }
  ]
}
